{
  "cleanUrls": true,
  "functions": {
    "api/research-provider.js": {
      "maxDuration": 120
    }
  },
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.carecircle.fit" }],
      "destination": "https://carecircle.fit/:path*",
      "permanent": true
    },
    {
      "source": "/:path(.*)\\.html",
      "destination": "/:path",
      "permanent": true
    },
    { "source": "/men", "destination": "/care-advocacy-for-men", "permanent": true }
  ],
  "rewrites": [
    { "source": "/blog/:slug", "destination": "/blog/:slug.html" }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
      ]
    }
  ]
}
