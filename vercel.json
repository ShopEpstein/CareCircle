{
  "cleanUrls": true,
  "redirects": [
    { "source": "/men", "destination": "/care-advocacy-for-men", "permanent": true }
  ],
  "rewrites": [
    { "source": "/blog/:slug", "destination": "/blog/:slug.html" }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
      ]
    }
  ]
}
